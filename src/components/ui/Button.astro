---
import Icon from './Icon.astro';

/** Button — anchor styled as the design's pill buttons. Composable variants. */
interface Props {
  variant?: 'primary' | 'secondary' | 'soft' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  icon?: string;
  iconPosition?: 'left' | 'right';
  full?: boolean;
  class?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href = '#',
  icon,
  iconPosition = 'right',
  full = false,
  class: className = '',
} = Astro.props;

const base =
  'group inline-flex items-center justify-center gap-2 rounded-[18px] font-semibold whitespace-nowrap transition-colors duration-200';

const sizes: Record<string, string> = {
  sm: 'px-[18px] py-3 text-[14px]',
  md: 'px-[22px] py-[13px] text-[15px]',
  lg: 'px-6 py-[15px] text-[15px]',
};

const variants: Record<string, string> = {
  primary:
    'bg-accent text-on-accent shadow-[0_4px_12px_rgba(24,24,27,0.15)] hover:bg-accent-ink',
  secondary: 'bg-surface text-ink border border-line hover:border-ink/25',
  soft: 'bg-bg text-ink border border-line hover:bg-bg-muted',
  ghost: 'text-ink-3 hover:text-ink',
};

const cls = [base, sizes[size], variants[variant], full ? 'w-full' : '', className]
  .filter(Boolean)
  .join(' ');
const iconSize = size === 'sm' ? 15 : 17;
---

<a href={href} class={cls}>
  {icon && iconPosition === 'left' && <Icon name={icon} size={iconSize} />}
  <slot />
  {icon && iconPosition === 'right' && <Icon name={icon} size={iconSize} />}
</a>
