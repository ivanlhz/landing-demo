---
import Badge from '../../ui/Badge.astro';
import Button from '../../ui/Button.astro';
import FeatureItem from '../../ui/FeatureItem.astro';

const columns = [
  ['Usuarios ilimitados', 'Roadmap y sprints', 'Automatizaciones', 'Importador de Jira'],
  ['Informes y OKR', 'Integraciones nativas', 'SSO / SAML', 'Soporte prioritario'],
];
---

<div
  class="flex flex-col gap-6 rounded-[40px] border-[1.5px] border-accent bg-surface p-9 shadow-[0_20px_44px_-14px_rgba(24,24,27,0.08)]"
>
  <!-- Header -->
  <div class="flex items-start justify-between gap-4">
    <div class="flex flex-col gap-2.5">
      <span class="text-[20px] font-bold text-ink">Pro</span>
      <div class="flex items-end gap-1.5">
        <span class="font-mono text-[48px] font-semibold leading-none tracking-[-2px] text-ink">€9</span>
        <span class="pb-[9px] font-mono text-[13px] text-ink-3">/ usuario · mes</span>
      </div>
    </div>
    <Badge icon="sparkles" class="px-3 py-1.5">Recomendado</Badge>
  </div>

  <div class="h-px w-full bg-line"></div>

  <!-- Feature columns -->
  <div class="grid gap-x-6 gap-y-3 sm:grid-cols-2">
    {
      columns.map((col) => (
        <div class="flex flex-col gap-3">
          {col.map((f) => <FeatureItem marker="circle">{f}</FeatureItem>)}
        </div>
      ))
    }
  </div>

  <Button href="#empieza" size="lg" icon="arrow-right" full class="px-5 shadow-[0_6px_14px_rgba(24,24,27,0.15)]">
    Empezar con Pro
  </Button>
</div>
