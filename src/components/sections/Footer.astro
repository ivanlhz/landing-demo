---
import Section from '../ui/Section.astro';
import Logo from '../ui/Logo.astro';
import Icon from '../ui/Icon.astro';
import FooterColumn from './footer/FooterColumn.astro';

const columns = [
  { title: 'Producto', links: ['Roadmap', 'Sprints', 'Automatizaciones', 'Precios'] },
  { title: 'Empresa', links: ['Sobre nosotros', 'Clientes', 'Empleo'] },
  { title: 'Recursos', links: ['Docs', 'Blog', 'Plantillas', 'Estado'] },
];
const socials = ['github', 'twitter', 'linkedin'] as const;
---

<Section as="footer" bg="bg-bg" border="top" class="flex flex-col gap-10 py-14">
  <div class="flex flex-col justify-between gap-12 lg:flex-row">
    <!-- Brand -->
    <div class="flex max-w-[320px] flex-col gap-3.5">
      <Logo size="sm" />
      <p class="max-w-[280px] text-[14px] leading-[1.5] text-ink-2">
        El sistema operativo de producto para equipos de 5 a 20 personas.
      </p>
    </div>

    <!-- Link columns -->
    <div class="grid grid-cols-2 gap-10 sm:grid-cols-3 lg:gap-16">
      {columns.map((col) => <FooterColumn title={col.title} links={col.links} />)}
    </div>
  </div>

  <div class="h-px w-full bg-line"></div>

  <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
    <span class="font-mono text-[12px] text-ink-3">© 2026 Stride Labs</span>
    <div class="flex items-center gap-4">
      {
        socials.map((s) => (
          <a href="#" aria-label={s} class="text-ink-3 transition-colors hover:text-ink">
            <Icon name={s} size={18} />
          </a>
        ))
      }
    </div>
  </div>
</Section>
