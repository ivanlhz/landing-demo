---
import Icon from '../../ui/Icon.astro';
---

<!-- Prompt input -->
<div class="flex flex-col gap-1.5 rounded-[18px] border border-line bg-bg px-4 py-3.5">
  <span class="font-mono text-[11px] tracking-[0.6px] text-ink-3">PREGUNTA</span>
  <div class="flex items-center gap-2.5">
    <Icon name="terminal" size={16} class="text-accent" />
    <span class="flex-1 text-[14px] text-ink">¿Qué bloquea el lanzamiento?</span>
    <span class="h-[18px] w-0.5 animate-pulse bg-accent"></span>
  </div>
</div>

<!-- Answer skeleton -->
<div class="flex flex-col gap-2 px-0.5 py-1">
  <span class="h-[9px] w-[80%] rounded-full bg-bg-muted"></span>
  <span class="h-[9px] w-[65%] rounded-full bg-bg-muted"></span>
  <span class="h-[9px] w-[72%] rounded-full bg-bg-muted"></span>
</div>

<!-- Result -->
<span
  class="inline-flex w-fit items-center gap-[7px] rounded-full bg-accent-soft px-[11px] py-1.5 font-mono text-[12px] text-accent-ink"
>
  <Icon name="circle-alert" size={14} class="text-accent" />
  3 bloqueos detectados
</span>
