---
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
---

<Section id="empieza" bg="bg-bg-muted" class="py-10">
  <div
    class="flex flex-col justify-between gap-10 overflow-hidden rounded-[40px] bg-ink p-9 sm:p-12 lg:flex-row lg:items-end lg:p-14"
  >
    <!-- Copy -->
    <div class="flex max-w-[640px] flex-col gap-3">
      <span class="font-mono text-[12px] uppercase tracking-[1.5px] text-accent">
        Empieza hoy
      </span>
      <h2
        class="text-[28px] font-semibold leading-[1.05] tracking-[-1.4px] text-bg sm:text-[32px] lg:text-[36px]"
      >
        Empieza a enviar producto esta semana.
      </h2>
      <p class="max-w-[520px] text-[16px] leading-[1.5] text-ink-3">
        Gratis hasta 10 personas. Migra desde Jira en minutos, sin tarjeta.
      </p>
    </div>

    <!-- Actions -->
    <div class="flex shrink-0 flex-col items-start gap-3 lg:items-end">
      <Button href="#empieza" size="lg" icon="arrow-right">Crear cuenta gratis</Button>
      <a
        href="#ventas"
        class="px-[18px] py-3 text-[14px] font-medium text-ink-3 transition-colors hover:text-bg"
      >
        Hablar con ventas
      </a>
    </div>
  </div>
</Section>
