---
import Icon from '../../ui/Icon.astro';
import Badge from '../../ui/Badge.astro';

const tasks = [
  { label: 'Cerrar specs de onboarding', done: true, who: 'MV' },
  { label: 'Revisar diseño del roadmap', done: false, who: 'JL' },
  { label: 'QA del importador de Jira', done: false, who: 'AK' },
];
---

<div class="relative w-full max-w-[400px]">
  <!-- Sprint card -->
  <div
    class="flex flex-col gap-[18px] rounded-[28px] border border-line bg-surface p-6 shadow-[0_24px_50px_-12px_rgba(24,24,27,0.10)]"
  >
    <!-- Header -->
    <div class="flex items-center justify-between">
      <span class="text-[16px] font-semibold text-ink">Sprint 14</span>
      <Badge dot>En curso</Badge>
    </div>

    <!-- Progress -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <span class="font-mono text-[11px] tracking-[0.3px] text-ink-3">Progreso</span>
        <span class="font-mono text-[13px] font-semibold text-ink">67%</span>
      </div>
      <div class="h-2 w-full overflow-hidden rounded-full bg-bg-muted">
        <div class="h-full w-[67%] rounded-full bg-accent"></div>
      </div>
    </div>

    <div class="h-px w-full bg-line"></div>

    <!-- Task list -->
    <ul class="flex flex-col gap-3.5">
      {
        tasks.map((t) => (
          <li class="flex items-center gap-3">
            {t.done ? (
              <span class="flex h-[18px] w-[18px] items-center justify-center rounded-[6px] bg-accent">
                <Icon name="check" size={12} class="text-on-accent" />
              </span>
            ) : (
              <span class="h-[18px] w-[18px] rounded-[6px] border-[1.5px] border-line" />
            )}
            <span
              class:list={[
                'flex-1 text-[13px] font-medium',
                t.done ? 'text-ink-3 line-through decoration-ink-3/40' : 'text-ink',
              ]}
            >
              {t.label}
            </span>
            <span class="flex h-[22px] w-[22px] items-center justify-center rounded-full border border-line bg-bg-muted font-mono text-[9px] text-ink-3">
              {t.who}
            </span>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Floating "deliveries" pill -->
  <div
    class="absolute -right-3 top-11 flex items-center gap-2 rounded-[18px] bg-ink px-[14px] py-2.5 shadow-[0_10px_24px_-4px_rgba(24,24,27,0.20)] sm:-right-5"
  >
    <Icon name="trending-up" size={16} class="text-accent" />
    <div class="flex flex-col leading-tight">
      <span class="text-[13px] font-semibold text-bg">+12 entregas</span>
      <span class="font-mono text-[10px] text-ink-3">esta semana</span>
    </div>
  </div>
</div>
