---
import Logo from '../ui/Logo.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

const links = [
  { label: 'Producto', href: '#producto' },
  { label: 'Precios', href: '#precios' },
  { label: 'Docs', href: '#docs' },
  { label: 'Blog', href: '#blog' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-line/60 bg-bg/85 backdrop-blur-md">
  <nav class="page-shell flex items-center justify-between py-[18px] lg:py-[22px]">
    <Logo />

    <ul class="hidden items-center gap-[34px] md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="font-mono text-[13px] tracking-[0.2px] text-ink-2 transition-colors hover:text-ink"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3 sm:gap-5">
      <a
        href="#entrar"
        class="hidden text-[15px] font-medium text-ink-2 transition-colors hover:text-ink sm:inline"
        >Entrar</a
      >
      <span class="hidden sm:block">
        <Button href="#empieza" size="md">Empieza</Button>
      </span>

      <button
        type="button"
        aria-label="Abrir menú"
        class="flex h-10 w-10 items-center justify-center rounded-[12px] border border-line text-ink sm:hidden"
      >
        <Icon name="menu" size={20} />
      </button>
    </div>
  </nav>
</header>
